# OpenAI API Configuration
# Realtime voice does not need a browser OpenAI key.
# Put OPENAI_API_KEY into orchestra/.env.orchestra instead.
# This key is only for legacy direct-browser Whisper/TTS experiments.
VITE_OPENAI_API_KEY=

# Optional: Override default API base URL
# VITE_OPENAI_API_BASE=https://api.openai.com/v1

# Application Configuration
VITE_API_BASE=http://localhost:8181
VITE_CHARACTER_SETTINGS_DISABLED=false
